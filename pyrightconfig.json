{
  "include": ["api"],
  "exclude": [
    "**/__pycache__",
    ".venv",
    "web"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "extraPaths": ["api"],
  "pythonVersion": "3.12",
  "typeCheckingMode": "basic",
  "reportMissingImports": "error",
  "reportImplicitRelativeImport": "none",
  "reportUnusedCallResult": "none",
  "reportDeprecated": "warning"
}
