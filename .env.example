# PDF to PPT Converter - Environment Variables

# File upload limits
MAX_FILE_MB=100
MAX_PAGES=200

# Job configuration
JOB_TTL_MINUTES=60
# Keepalive interval (seconds) to refresh Redis TTL during long blocking stages
JOB_KEEPALIVE_INTERVAL_S=15

# Redis connection
REDIS_URL=redis://redis:6379/0

# Optional: remote OCR defaults (used by QA scripts and legacy v2 alias)
# Do NOT commit real keys. Prefer setting these in your deployment environment.
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# Recommended OCR model examples:
# - Pro/deepseek-ai/deepseek-ocr
# - PaddlePaddle/PaddleOCR-VL-1.5
SILICONFLOW_MODEL=Pro/deepseek-ai/deepseek-ocr

# OCR timeout guards
OCR_PAGE_TIMEOUT_S=300
OCR_MAX_CONSECUTIVE_TIMEOUTS=2
OCR_TOTAL_TIMEOUT_S=3600
# Optional per-request timeout (seconds) for AI OCR calls
OCR_AI_REQUEST_TIMEOUT_S=25
# Optional model-specific overrides (useful when VL models are slower)
# OCR_AI_REQUEST_TIMEOUT_S_QWEN=90
# OCR_AI_REQUEST_TIMEOUT_S_DEEPSEEK_OCR=45
# OCR_AI_REQUEST_TIMEOUT_S_PADDLE_VL=60
# Optional PaddleOCR-VL doc_parser controls (remote channel tuning)
# OCR_PADDLE_VL_DOCPARSER_MAX_CONCURRENCY=4
# OCR_PADDLE_VL_DOCPARSER_USE_QUEUES=1
# OCR_PADDLE_VL_PIPELINE_VERSION=v1.5
# OCR_PADDLE_VL_DOCPARSER_INIT_TIMEOUT_S=30
# OCR_PADDLE_VL_DOCPARSER_MAX_SIDE_PX=2200
# OCR_PADDLE_VL_DOCPARSER_MAX_PIXELS=
# OCR_PADDLE_VL_DOCPARSER_PREDICT_TIMEOUT_S=120
# OCR_PADDLE_VL_DOCPARSER_PREDICT_TIMEOUT_S_V15=180
# OCR_PADDLE_VL_DOCPARSER_PREDICT_TIMEOUT_S_V15_SILICONFLOW=60
# OCR_PADDLE_VL_DOCPARSER_RETRY_ON_TIMEOUT=1
# For SiliconFlow + PaddleOCR-VL-1.5 we default to no retry and singleflight
# request serialization. Override only if you explicitly want the old behavior.
# OCR_PADDLE_VL_DOCPARSER_RETRY_ON_TIMEOUT_V15_SILICONFLOW=0
# OCR_PADDLE_VL_DOCPARSER_SINGLEFLIGHT=1
# OCR_PADDLE_VL_DOCPARSER_SINGLEFLIGHT_WAIT_S=1
# OCR_PADDLE_VL_DOCPARSER_RETRY_TIMEOUT_S=90

# Optional PaddleOCR-VL startup prewarm for container deployments.
# Recommended on VPS after you set a PaddleOCR-VL model and valid SiliconFlow key.
# OCR_PADDLE_VL_PREWARM=1
# OCR_PADDLE_VL_PREWARM_TARGET=worker
# OCR_PADDLE_VL_PREWARM_REQUIRED=0
# OCR_PADDLE_VL_PREWARM_PROVIDER=siliconflow
# OCR_PADDLE_VL_PREWARM_API_KEY=
# OCR_PADDLE_VL_PREWARM_BASE_URL=
# OCR_PADDLE_VL_PREWARM_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
# OCR_PADDLE_VL_PREWARM_MAX_SIDE_PX=2200

# CORS settings for public deployment
# Comma-separated list, e.g. http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex, e.g. https://.*\\.your-domain\\.com
CORS_ALLOW_ORIGIN_REGEX=
